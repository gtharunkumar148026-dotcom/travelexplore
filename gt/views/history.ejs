<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>View History</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
  <style>
    body {
      background-image: url('https://cdn.pixabay.com/photo/2021/08/22/15/48/nature-6565499_1280.jpg');
      background-size: cover;
      background-position: center;
      min-height: 100vh;
      padding: 2rem;
      color: white;
    }

    .card {
      background: rgba(255, 255, 255, 0.9);
      color: black;
    }

    h2 {
      text-shadow: 2px 2px 4px rgba(0,0,0,0.6);
    }
  </style>
</head>
<body>
  <h2 class="mb-4" style="color: brown;">Recently Viewed Destinations</h2>
  <% if (history.length === 0) { %>
    <p>No destinations viewed yet.</p>
  <% } else { %>
    <div class="row">
      <% history.forEach(dest => { %>
        <div class="col-md-4 mb-4">
          <div class="card h-100 shadow">
            <% if (dest.image) { %>
              <img src="<%= dest.image %>" class="card-img-top" alt="<%= dest.name %>">
            <% } %>
            <div class="card-body">
              <h5 class="card-title"><%= dest.name %></h5>
              <p class="card-text"><%= dest.description %></p>
              <p><small class="text-muted">Viewed on <%= new Date(dest.viewedAt).toLocaleString() %></small></p>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</body>
</html>
