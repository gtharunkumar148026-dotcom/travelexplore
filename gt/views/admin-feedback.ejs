<!DOCTYPE html>
<html>
<head>
  <title>Admin - User Logins</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="container mt-5">
  <h2>Logged-in Users</h2>
  <table class="table table-striped">
    <thead>
      <tr>
        <th>Name</th>
        <th>Email</th>
        <th>Last Login</th>
      </tr>
    </thead>
    <tbody>
      <% users.forEach(user => { %>
        <tr>
          <td><%= user.fullName %></td>
          <td><%= user.email %></td>
          <td><%= user.loginTime ? user.loginTime.toLocaleString() : "Not available" %></td>
        </tr>
      <% }) %>
    </tbody>
  </table>
</body>
</html>
